<Window x:Class="Smart_BIMs.UI.AboutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="About Smart BIMs" Height="250" Width="350"
        WindowStartupLocation="CenterScreen"
        Background="#1E1E1E">
    <Grid Margin="20">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="Smart BIMs" Foreground="#007BFF" FontWeight="Bold" FontSize="26" HorizontalAlignment="Center"/>
            <TextBlock Text="Version 1.0.0" Foreground="#CCCCCC" FontSize="14" HorizontalAlignment="Center" Margin="0,5,0,15"/>
            
            <TextBlock Text="Publisher: Asanka Dharmarathna" Foreground="#FFFFFF" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="AcademyInnov" Foreground="#FFFFFF" FontSize="14" HorizontalAlignment="Center"/>
            
            <Button Content="Visit academyinnov.com" Width="200" Height="35" Margin="0,20,0,0" Click="WebLink_Click"
                    Background="#007BFF" Foreground="White" BorderThickness="0" FontSize="14" Cursor="Hand"/>
        </StackPanel>
    </Grid>
</Window>
