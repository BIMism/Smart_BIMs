<Window x:Class="Smart_BIMs.UI.AddFieldWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Add Field Live" Height="400" Width="350" WindowStartupLocation="CenterScreen" Background="#F0F4F8">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Push New Field to Live Excel Session:" FontWeight="Bold" FontSize="14" Foreground="#0A192F" Margin="0,0,0,10"/>
        
        <ListBox x:Name="lstFields" Grid.Row="1" BorderBrush="#DDDDDD" BorderThickness="1">
            <ListBox.ItemTemplate>
                <DataTemplate>
                    <CheckBox Content="{Binding Name}" IsChecked="{Binding IsSelected}" Margin="3"/>
                </DataTemplate>
            </ListBox.ItemTemplate>
        </ListBox>
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Push Live" Width="100" Height="30" Background="#28a745" Foreground="White" FontWeight="Bold" BorderThickness="0" Margin="0,0,10,0" Click="BtnPush_Click"/>
            <Button Content="Cancel" Width="80" Height="30" Background="LightGray" BorderThickness="0" Click="BtnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
