<Window x:Class="Smart_BIMs.UI.EasyScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Easy Schedule Creator" Height="400" Width="300"
        WindowStartupLocation="CenterScreen">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        
        <TextBlock Text="Select Categories to Schedule:" FontWeight="Bold" Margin="0,0,0,5"/>
        
        <ListBox x:Name="CategoryListBox" Grid.Row="1" SelectionMode="Multiple" DisplayMemberPath="Name" Margin="0,5,0,5" />
        
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button Content="Create Schedules" Width="120" Height="30" Margin="0,0,10,0" Click="CreateButton_Click"/>
            <Button Content="Cancel" Width="80" Height="30" Click="CancelButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
